<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="qube">

  <xacro:include filename="$(find qube_description)/urdf/qube.urdf.xacro"/>

  <link name="world"/>

  <xacro:qube prefix=""/>

  <joint name="world_joint" type="fixed">       <!-- plasser Quben i origo -->
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>